---
import IndexLayout from "../layouts/indexLayout.astro";
import "../styles/index/components/hero.css";
import BarChartComponent from "../components/index/BarChartComponent.astro";
import PieChartComponent from"../components/index/PieChartComponent.astro"
import CardComponent from "../components/services/ServiceCardComponent.astro"

const heroImg = '/assets/hero_section_img.png'
---


<IndexLayout title="Despacho BC">
	<section class="hero">
		<div class="shapeWrapper">
			<div class="shape shape-1"></div>
			<div class="shape shape-2"></div>
		</div>

		<div class="heroContent">
			<div class="hero-content-left">
				<div class="hero-title">
					<h1 class="hero-title-black">Despacho</h1><h1 class="hero-title-green">BC</h1>
				</div>
				<p class="description">Somos un despacho con más de 25 años de experiencia.
					Estamos comprometidos con la excelencia, nuestro equipo de contadores 
					certificados cuentan con capacitación constante y actualizada.
				</p>
				<h3 class="impact-phrase">Frase de impacto</h3>
				<div class="attention-content">
					<div class="attention-text">
						<p>Ofrecemos atención personalizada, garantizando soluciones contables precisas y un acompañamiento constante en cada paso.</p>
					</div>
					<BarChartComponent />
				</div>
			</div>
			<div class="hero-content-right">
				<img src={heroImg} alt="" class="heroImage"/>
			</div>
		</div>
	</section>

	<section class="confianza">
		<PieChartComponent />
	</section>
	<section class="servicios">
		<CardComponent />
	</section>
	<section class="sobre-nosotros">

	</section>
	<section class="nuestro-compromiso">

	</section>
	<section class="casos-de-exito">

	</section>
	<section class="contacto">

	</section>
</IndexLayout>
